#!/bin/sh
. /usr/share/openclash/ruby.sh
. /usr/share/openclash/log.sh
. /lib/functions.sh

LOG_OUT "Tip: 开始执行 Gemini 专属分流覆写脚本..."
CONFIG_FILE="$1"

# =========================================================
# 第 1 步：添加我们自己的节点订阅 (Proxy Provider)
# 我们给它起名叫 'My_Custom_Provider'
# ⚠️ 请务必把 URL 替换为你真实的订阅链接！
# =========================================================
LOG_OUT "正在添加自定义 Proxy Provider..."

ruby_merge_hash "$CONFIG_FILE" "['proxy-providers']" "'My_Custom_Provider'=>{'type'=>'http', 'url'=>'https://msub.xn--m7r52rosihxm.com/api/v1/client/subscribe?token=b480c85d9609e7214848a578f1e9b90a', 'path'=>'./proxy_provider/my_custom.yaml', 'interval'=>3600, 'health-check'=>{'enable'=>true, 'url'=>'http://cp.cloudflare.com/generate_204', 'interval'=>300}}"


# =========================================================
# 第 2 步：插入策略组 (Proxy Groups)
# 现在我们可以放心大胆地在 'use' 里填入 'My_Custom_Provider' 了！
# =========================================================
LOG_OUT "正在添加策略组..."

# 第 1 个插入：✨ Gemini-Rule 手动选择组
ruby_arr_insert_hash "$CONFIG_FILE" "['proxy-groups']" "-1" "{'name'=>'✨ Gemini-Rule', 'type'=>'select', 'proxies'=>['🤖 Gemini-Fallback', '🇸🇬 SG-Fallback', '🇭🇰HK-Fallback', '🇭🇰HK-🇸🇬SG-select', 'DIRECT']}"

# 第 2 个插入：🇸🇬 SG-Fallback 新加坡故障转移组 (type 已改为 fallback)
ruby_arr_insert_hash "$CONFIG_FILE" "['proxy-groups']" "-1" "{'name'=>'🇸🇬 SG-Fallback', 'type'=>'fallback', 'url'=>'http://cp.cloudflare.com/generate_204', 'interval'=>300, 'filter'=>'(?i)新加坡|SG|Singapore', 'use'=>['My_Custom_Provider']}"

ruby_arr_insert_hash "$CONFIG_FILE" "['proxy-groups']" "-1" "{'name'=>'🇭🇰HK-Fallback', 'type'=>'fallback', 'url'=>'http://cp.cloudflare.com/generate_204', 'interval'=>300, 'filter'=>'(?i)香港', 'use'=>['My_Custom_Provider']}"
# 第 3 个插入：🤖 Gemini-Fallback 节点故障转移组 (type 已改为 fallback)
ruby_arr_insert_hash "$CONFIG_FILE" "['proxy-groups']" "-1" "{'name'=>'🤖Gemini-Fallback', 'type'=>'fallback', 'url'=>'http://cp.cloudflare.com/generate_204', 'interval'=>300, 'filter'=>'(?i)Gemini', 'use'=>['My_Custom_Provider']}"

ruby_arr_insert_hash "$CONFIG_FILE" "['proxy-groups']" "-1" "{'name'=>'🇭🇰HK-🇸🇬SG-select', 'type'=>'select', 'url'=>'http://cp.cloudflare.com/generate_204', 'interval'=>300, 'filter'=>'(?i)香港|HK|HongKong|新加坡|SG|Singapore', 'use'=>['My_Custom_Provider']}"

# =========================================================
# 第 3 步：插入分流规则 (Rules)
# =========================================================
# =========================================================
# 2. 添加分流规则 (包含 Google 官方给出的所有 Gemini 依赖域名)
# 必须使用 0 插在顶部，确保最高优先级
